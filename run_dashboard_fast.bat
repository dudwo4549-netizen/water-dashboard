@echo off
chcp 65001 > nul
title 💧 상수도 대시보드 로컬 실행기 (경량형)

echo ====================================================================
echo   💧 상수도 통합 성과관리 및 AI 기술자문 시스템 (경량 기동기)
echo ====================================================================
echo.
echo   * 본 실행기는 별도의 파이썬 라이브러리(Flask, Pandas 등) 설치 없이
echo     파이썬 내장 기능을 사용하여 대시보드를 빠르고 안정적으로 실행합니다.
echo.
echo   * 대시보드 웹 브라우저를 실행합니다...
start "" "http://127.0.0.1:5000"

echo   * 로컬 웹 서버를 구동합니다 (포트: 5000).
echo   * 서버를 종료하려면 이 창을 닫거나 Ctrl+C를 누르십시오.
echo ====================================================================
echo.

cd /d "%~dp0dashboard"
python -m http.server 5000

pause
